{
    "version": 2,
    "buildCommand": "cd frontend && npm install --include=dev && node node_modules/vite/bin/vite.js build",
    "outputDirectory": "dist",
    "functions": {
      "api/**/*.js": {
        "runtime": "nodejs20.x"
      }
    },
    "rewrites": [
      { "source": "/api/(.*)", "destination": "/api/$1" },
      { "source": "/(.*)", "destination": "/index.html" }
    ]
  }