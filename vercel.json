{
    "version": 2,
    "buildCommand": "npm install --include=dev && npx vite build",
    "outputDirectory": "dist",
    "functions": {
      "api/**/*.js": {
        "runtime": "nodejs20.x"
      }
    },
    "rewrites": [
      { "source": "/api/(.*)", "destination": "/api/$1" },
      { "source": "/(.*)", "destination": "/index.html" }
    ]
  }